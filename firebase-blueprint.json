{
  "entities": {
    "Chat": {
      "title": "Chat",
      "description": "A conversation session for a specific subject",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subject", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a chat",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "content", "createdAt"]
    },
    "Source": {
      "title": "Source",
      "description": "A study material source (PDF text or pasted text)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "text"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "content", "createdAt"]
    }
  },
  "firestore": {
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Collection of chat sessions"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat session"
    },
    "/chats/{chatId}/sources/{sourceId}": {
      "schema": "Source",
      "description": "Study material sources for a chat session"
    }
  }
}
